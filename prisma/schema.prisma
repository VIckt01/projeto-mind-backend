datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  bio       String?  @db.VarChar(500) // Limite de 500 caracteres
  avatarUrl String?  @db.Text         // Guarda o link da foto
  role      String   @default("Admin") // Tipo de conta exigido no Figma
  createdAt DateTime @default(now())
  articles  Article[]
  
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  banner    Bytes?   // Armazena a imagem como BLOB (binário) no MySQL
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
